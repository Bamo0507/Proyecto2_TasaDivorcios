train_reg <- train_num %>%
filter(!is.na(price), is.finite(price), price >= 0)
test_reg <- test_num %>%
filter(!is.na(price), is.finite(price), price >= 0)
x_train_reg <- train_reg %>% select(-price)
x_test_reg  <- test_reg  %>% select(-price)
nzv_reg <- caret::nearZeroVar(x_train_reg, names = TRUE)
if (length(nzv_reg) > 0) {
x_train_reg <- x_train_reg %>% select(-all_of(nzv_reg))
x_test_reg  <- x_test_reg  %>% select(-all_of(nzv_reg))
}
reg_center <- colMeans(x_train_reg)
reg_sd <- apply(x_train_reg, 2, sd)
reg_sd[is.na(reg_sd) | reg_sd == 0] <- 1
train_reg_svm <- as.data.frame(scale(x_train_reg, center = reg_center, scale = reg_sd))
test_reg_svm  <- as.data.frame(scale(x_test_reg,  center = reg_center, scale = reg_sd))
train_reg_svm$price <- train_reg$price
test_reg_svm$price  <- test_reg$price
cat("Observaciones de entrenamiento para regresion:", nrow(train_reg_svm), "\n")
cat("Observaciones de prueba para regresion:", nrow(test_reg_svm), "\n")
set.seed(456)
n_svr_tune <- min(1500, nrow(train_reg_svm))
idx_svr_tune <- sample(seq_len(nrow(train_reg_svm)), n_svr_tune)
train_svr_tune <- train_reg_svm[idx_svr_tune, ]
tune_svr <- tune(
svm,
price ~ .,
data = train_svr_tune,
kernel = "radial",
ranges = list(
cost = c(1, 10, 100),
gamma = c(0.001, 0.005, 0.01),
epsilon = c(0.1, 0.5, 1)
),
tunecontrol = tune.control(sampling = "cross", cross = 5)
)
cat("Mejores parametros del SVR:\n")
print(tune_svr$best.parameters)
cat("\nError de validacion cruzada:", round(tune_svr$best.performance, 4), "\n")
set.seed(456)
n_svr_final <- min(5000, nrow(train_reg_svm))
idx_svr_final <- sample(seq_len(nrow(train_reg_svm)), n_svr_final)
train_svr_final <- train_reg_svm[idx_svr_final, ]
tiempo_svr_train <- system.time(
modelo_svr <- svm(
price ~ .,
data = train_svr_final,
kernel = "radial",
cost = tune_svr$best.parameters$cost,
gamma = tune_svr$best.parameters$gamma,
epsilon = tune_svr$best.parameters$epsilon,
scale = FALSE
)
)
tiempo_svr_pred <- system.time({
pred_svr_train <- as.numeric(predict(modelo_svr, newdata = train_reg_svm))
pred_svr_test  <- as.numeric(predict(modelo_svr, newdata = test_reg_svm))
})
pred_svr_train <- pmax(0, pred_svr_train)
pred_svr_test  <- pmax(0, pred_svr_test)
metricas_svr <- calc_reg_row(
"SVR radial",
train_reg_svm$price,
pred_svr_train,
test_reg_svm$price,
pred_svr_test
)
knitr::kable(
metricas_svr,
caption = "Métricas del modelo SVR",
digits = 4
)
cat("Tiempo de entrenamiento SVR:", round(tiempo_svr_train["elapsed"], 4), "s\n")
cat("Tiempo de prediccion SVR:", round(tiempo_svr_pred["elapsed"], 4), "s\n")
set.seed(789)
train_reg_lm <- train_reg %>% select(price, all_of(names(x_train_reg)))
test_reg_lm  <- test_reg  %>% select(price, all_of(names(x_train_reg)))
modelo_lm <- lm(price ~ ., data = train_reg_lm)
pred_lm_train <- pmax(0, as.numeric(predict(modelo_lm, newdata = train_reg_lm)))
pred_lm_test  <- pmax(0, as.numeric(predict(modelo_lm, newdata = test_reg_lm)))
modelo_arbol_reg <- rpart(
price ~ .,
data = train_reg_lm,
method = "anova",
control = rpart.control(cp = 0.001, minsplit = 30)
)
pred_arbol_reg_train <- pmax(0, as.numeric(predict(modelo_arbol_reg, newdata = train_reg_lm)))
pred_arbol_reg_test  <- pmax(0, as.numeric(predict(modelo_arbol_reg, newdata = test_reg_lm)))
n_rf_reg <- min(10000, nrow(train_reg_lm))
train_rf_reg <- train_reg_lm[sample(seq_len(nrow(train_reg_lm)), n_rf_reg), ]
modelo_rf_reg <- randomForest(
price ~ .,
data = train_rf_reg,
ntree = 150,
mtry = max(1, floor(sqrt(ncol(train_rf_reg) - 1))),
importance = FALSE
)
pred_rf_reg_train <- pmax(0, as.numeric(predict(modelo_rf_reg, newdata = train_reg_lm)))
pred_rf_reg_test  <- pmax(0, as.numeric(predict(modelo_rf_reg, newdata = test_reg_lm)))
n_knn_reg <- min(8000, nrow(train_reg_svm))
train_knn_reg <- train_reg_svm[sample(seq_len(nrow(train_reg_svm)), n_knn_reg), ]
modelo_knn_reg <- caret::knnreg(
price ~ .,
data = train_knn_reg,
k = 7
)
pred_knn_reg_train <- pmax(0, as.numeric(predict(modelo_knn_reg, newdata = train_reg_svm)))
pred_knn_reg_test  <- pmax(0, as.numeric(predict(modelo_knn_reg, newdata = test_reg_svm)))
metricas_regresion <- bind_rows(
calc_reg_row("Regresión lineal", train_reg_lm$price, pred_lm_train,
test_reg_lm$price, pred_lm_test),
calc_reg_row("Árbol de regresión", train_reg_lm$price, pred_arbol_reg_train,
test_reg_lm$price, pred_arbol_reg_test),
calc_reg_row("Random Forest", train_reg_lm$price, pred_rf_reg_train,
test_reg_lm$price, pred_rf_reg_test),
calc_reg_row("KNN regresión", train_reg_svm$price, pred_knn_reg_train,
test_reg_svm$price, pred_knn_reg_test),
metricas_svr
) %>%
mutate(
Diagnostico = diagnostico_reg(RMSE_Train, RMSE_Test, R2_Train, R2_Test)
) %>%
arrange(RMSE_Test)
mejor_modelo_reg <- metricas_regresion[which.min(metricas_regresion$RMSE_Test), ]
knitr::kable(
metricas_regresion,
caption = "Comparación de modelos para predicción del precio",
digits = 4
)
setwd("~/Documents/Mineria_de_Datos/Proyecto1_INE/Proyecto2_TasaDivorcios")
knitr::opts_chunk$set(echo = TRUE)
library(readr)
library(dplyr)
library(tidyverse)
library(stringr)
library(stringi)
library(ggplot2)
knitr::opts_chunk$set(echo = TRUE)
library(readr)
library(dplyr)
library(tidyverse)
library(stringr)
library(stringi)
library(ggplot2)
norm_depto <- function(x) {
x %>%
str_trim() %>%
str_squish() %>%
stri_trans_general("Latin-ASCII") %>%
str_to_lower()
}
matrimonios_anual <- read_csv("../matrimonios_depto_mes.csv", show_col_types = FALSE) %>%
filter(nivel_geo == "departamento", is.na(mes)) %>%
mutate(departamento = norm_depto(departamento)) %>%
group_by(anio, departamento) %>%
summarise(total_matrimonios = sum(valor, na.rm = TRUE), .groups = "drop")
divorcios_anual <- read_csv("../divorcios_depto_mes.csv", show_col_types = FALSE) %>%
filter(nivel_geo == "departamento", is.na(mes)) %>%
mutate(departamento = norm_depto(departamento)) %>%
group_by(anio, departamento) %>%
summarise(total_divorcios = sum(valor, na.rm = TRUE), .groups = "drop")
dataset_ine <- matrimonios_anual %>%
inner_join(divorcios_anual, by = c("anio", "departamento")) %>%
mutate(tasa_divorcio_por_100 = (total_divorcios / total_matrimonios) * 100)
archivos_gdl <- list.files(pattern = "GDL-Human-Development.*\\.csv$")
gdl_consolidado <- map_dfr(archivos_gdl, read_csv, show_col_types = FALSE) %>%
filter(Level == "Subnat") %>%
select(region_gdl = Region, anio = Year, shdi, healthindex, edindex, incindex)
region_map <- tibble(
departamento = c(
"guatemala",
"alta verapaz", "baja verapaz",
"el progreso", "izabal", "zacapa", "chiquimula",
"santa rosa", "jalapa", "jutiapa",
"chimaltenango", "sacatepequez", "escuintla",
"san marcos", "quetzaltenango", "retalhuleu",
"suchitepequez", "solola", "totonicapan",
"huehuetenango", "quiche",
"peten"
),
region_gdl = c(
"Metropolitan",
"North", "North",
"North-Oriental", "North-Oriental", "North-Oriental", "North-Oriental",
"South-Oriental", "South-Oriental", "South-Oriental",
"Central", "Central", "Central",
"South-Occidental", "South-Occidental", "South-Occidental",
"South-Occidental", "South-Occidental", "South-Occidental",
"North-Occidental", "North-Occidental",
"Peten"
)
)
dataset_final <- dataset_ine %>%
left_join(region_map, by = "departamento") %>%
left_join(gdl_consolidado, by = c("region_gdl", "anio")) %>%
select(departamento, anio, total_matrimonios, total_divorcios,
shdi, healthindex, edindex, incindex,
tasa_divorcio_por_100)
glimpse(dataset_final)
cat("Observaciones totales:", nrow(dataset_final), "\n")
cat("Departamentos únicos:", n_distinct(dataset_final$departamento), "\n")
cat("Años cubiertos:", min(dataset_final$anio), "–", max(dataset_final$anio), "\n")
cat("Valores faltantes:\n")
colSums(is.na(dataset_final))
train_set <- dataset_final %>% filter(anio <= 2018)
test_set  <- dataset_final %>% filter(anio >  2018)
cat("Entrenamiento:", nrow(train_set), "observaciones",
sprintf("(%.1f%%)\n", 100 * nrow(train_set) / nrow(dataset_final)))
cat("Prueba:       ", nrow(test_set),  "observaciones",
sprintf("(%.1f%%)\n", 100 * nrow(test_set)  / nrow(dataset_final)))
Q1  <- quantile(dataset_final$tasa_divorcio_por_100, 0.25, na.rm = TRUE)
Q3  <- quantile(dataset_final$tasa_divorcio_por_100, 0.75, na.rm = TRUE)
IQR_val <- IQR(dataset_final$tasa_divorcio_por_100, na.rm = TRUE)
lim_inf <- Q1 - 1.5 * IQR_val
lim_sup <- Q3 + 1.5 * IQR_val
cat(sprintf("Q1: %.3f | Q3: %.3f | IQR: %.3f\n", Q1, Q3, IQR_val))
cat(sprintf("Límite inferior: %.3f | Límite superior: %.3f\n", lim_inf, lim_sup))
ggplot(dataset_final, aes(y = tasa_divorcio_por_100)) +
geom_boxplot(outlier.colour = "red", outlier.size = 2) +
labs(
title = "Distribución de la tasa de divorcio por cada 100 matrimonios",
y     = "Divorcios por cada 100 matrimonios"
) +
theme_minimal()
atipicos <- dataset_final %>%
filter(tasa_divorcio_por_100 > lim_sup | tasa_divorcio_por_100 < lim_inf) %>%
arrange(desc(tasa_divorcio_por_100))
cat("Total de observaciones atípicas:", nrow(atipicos), "\n\n")
atipicos %>% select(departamento, anio, tasa_divorcio_por_100, total_matrimonios, total_divorcios)
