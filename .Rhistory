tabla_ajuste <- data.frame(
Modelo = c("Lineal", "RBF", "RBF Tuneado"),
Acc_Train = round(c(acc(real_train, pred_lineal_train),
acc(real_train, pred_rbf_train),
acc(real_train, pred_rbf_tuned_train)), 4),
Acc_Test = round(c(acc(real_test, pred_lineal),
acc(real_test, pred_rbf),
acc(real_test, pred_rbf_tuned)), 4)
)
tabla_ajuste$Diferencia <- round(tabla_ajuste$Acc_Train - tabla_ajuste$Acc_Test, 4)
knitr::kable(tabla_ajuste, col.names = c("Modelo", "Accuracy Train", "Accuracy Test", "Diferencia"),
caption = "Comparación de exactitud en entrenamiento y prueba")
extraer_f1 <- function(cm, clase) {
if (is.null(dim(cm$byClass)) || !"F1" %in% colnames(cm$byClass)) {
return(NA_real_)
}
fila <- grep(clase, rownames(cm$byClass), fixed = TRUE)
if (length(fila) == 0) return(NA_real_)
as.numeric(cm$byClass[fila[1], "F1"])
}
tabla_comp <- data.frame(
Modelo = c("Lineal", "RBF", "RBF Tuneado"),
Accuracy = c(
as.numeric(cm_lineal$overall["Accuracy"]),
as.numeric(cm_rbf$overall["Accuracy"]),
as.numeric(cm_rbf_tuned$overall["Accuracy"])
),
Kappa = c(
as.numeric(cm_lineal$overall["Kappa"]),
as.numeric(cm_rbf$overall["Kappa"]),
as.numeric(cm_rbf_tuned$overall["Kappa"])
),
F1_Economica = c(
extraer_f1(cm_lineal, "Economica"),
extraer_f1(cm_rbf, "Economica"),
extraer_f1(cm_rbf_tuned, "Economica")
),
F1_Intermedia = c(
extraer_f1(cm_lineal, "Intermedia"),
extraer_f1(cm_rbf, "Intermedia"),
extraer_f1(cm_rbf_tuned, "Intermedia")
),
F1_Cara = c(
extraer_f1(cm_lineal, "Cara"),
extraer_f1(cm_rbf, "Cara"),
extraer_f1(cm_rbf_tuned, "Cara")
),
Errores = c(
sum(as.character(pred_lineal) != as.character(test_svm$price_cat)),
sum(as.character(pred_rbf) != as.character(test_svm$price_cat)),
sum(as.character(pred_rbf_tuned) != as.character(test_svm$price_cat))
),
Tiempo_pred = c(
as.numeric(tiempo_lineal["elapsed"]),
as.numeric(tiempo_rbf["elapsed"]),
as.numeric(tiempo_rbf_tuned["elapsed"])
)
)
knitr::kable(tabla_comp,
col.names = c("Modelo", "Accuracy", "Kappa", "F1 Economica",
"F1 Intermedia", "F1 Cara", "Errores", "Tiempo pred (s)"),
caption = "Comparación de métricas entre los tres modelos SVM",
digits = 4
)
set.seed(123)
modelo_arbol_clf <- rpart(
price_cat ~ .,
data = train_tree_clf,
method = "class",
control = rpart.control(cp = 0.005, minsplit = 30)
)
n_rf_clf <- min(10000, nrow(train_tree_clf))
train_rf_clf <- train_tree_clf[sample(seq_len(nrow(train_tree_clf)), n_rf_clf), ]
modelo_rf_clf <- randomForest(
price_cat ~ .,
data = train_rf_clf,
ntree = 150,
mtry = max(1, floor(sqrt(ncol(train_rf_clf) - 1))),
importance = FALSE
)
modelo_nb_clf <- e1071::naiveBayes(
price_cat ~ .,
data = train_tree_clf,
laplace = 1
)
n_knn_clf <- min(8000, nrow(train_svm))
train_knn_clf <- train_svm[sample(seq_len(nrow(train_svm)), n_knn_clf), ]
modelo_knn_clf <- caret::knn3(
price_cat ~ .,
data = train_knn_clf,
k = 21
)
modelo_logit_clf <- nnet::multinom(
price_cat ~ .,
data = train_svm,
trace = FALSE,
maxit = 300,
MaxNWts = 10000
)
pred_arbol_train <- predict(modelo_arbol_clf, newdata = train_tree_clf, type = "class")
pred_arbol_test  <- predict(modelo_arbol_clf, newdata = test_tree_clf,  type = "class")
pred_rf_train <- predict(modelo_rf_clf, newdata = train_tree_clf, type = "class")
pred_rf_test  <- predict(modelo_rf_clf, newdata = test_tree_clf,  type = "class")
pred_nb_train <- predict(modelo_nb_clf, newdata = train_tree_clf, type = "class")
pred_nb_test  <- predict(modelo_nb_clf, newdata = test_tree_clf,  type = "class")
pred_knn_train <- predict(modelo_knn_clf,
newdata = train_svm %>% select(-price_cat),
type = "class")
pred_knn_test  <- predict(modelo_knn_clf,
newdata = test_svm %>% select(-price_cat),
type = "class")
pred_logit_train <- predict(modelo_logit_clf, newdata = train_svm, type = "class")
pred_logit_test  <- predict(modelo_logit_clf, newdata = test_svm,  type = "class")
tabla_clf <- data.frame(
Modelo = c("Árbol de decisión", "Random Forest", "Naive Bayes",
"KNN", "Regresión logística", "SVM RBF Tuneado"),
Accuracy = c(
calc_acc(train_tree_clf$price_cat, pred_arbol_train),
calc_acc(train_tree_clf$price_cat, pred_rf_train),
calc_acc(train_tree_clf$price_cat, pred_nb_train),
calc_acc(train_svm$price_cat, pred_knn_train),
calc_acc(train_svm$price_cat, pred_logit_train),
calc_acc(train_svm$price_cat, pred_rbf_tuned_train)
),
Accuracy_Test = c(
calc_acc(test_tree_clf$price_cat, pred_arbol_test),
calc_acc(test_tree_clf$price_cat, pred_rf_test),
calc_acc(test_tree_clf$price_cat, pred_nb_test),
calc_acc(test_svm$price_cat, pred_knn_test),
calc_acc(test_svm$price_cat, pred_logit_test),
calc_acc(test_svm$price_cat, pred_rbf_tuned)
)
)
tabla_clf <- tabla_clf %>%
mutate(
Brecha = Accuracy - Accuracy_Test
) %>%
arrange(desc(Accuracy_Test))
knitr::kable(
tabla_clf,
col.names = c("Modelo", "Accuracy Train", "Accuracy Test", "Brecha"),
caption = "Comparación de exactitud entre modelos de clasificación",
digits = 4
)
tabla_sobreajuste_clf <- data.frame(
Modelo = c("Árbol de decisión", "Random Forest", "Naive Bayes", "KNN",
"Regresión logística", "SVM Lineal", "SVM RBF", "SVM RBF Tuneado"),
Accuracy_Train = c(
calc_acc(train_tree_clf$price_cat, pred_arbol_train),
calc_acc(train_tree_clf$price_cat, pred_rf_train),
calc_acc(train_tree_clf$price_cat, pred_nb_train),
calc_acc(train_svm$price_cat, pred_knn_train),
calc_acc(train_svm$price_cat, pred_logit_train),
calc_acc(train_svm$price_cat, pred_lineal_train),
calc_acc(train_svm$price_cat, pred_rbf_train),
calc_acc(train_svm$price_cat, pred_rbf_tuned_train)
),
Accuracy_Test = c(
